        <!-- Fullres Events -->
        <script type="4904efa5dfa3998084977123-text/javascript">
            document.addEventListener('DOMContentLoaded', () => {
                // track free vector download button clicks
                const downloadButton = document.querySelector('.button-lg--download');
                if (downloadButton) {
                    downloadButton.addEventListener('click', () => {
                        window.fullres ||= {events: []};
                        window.fullres.events.push({ 
                            key: 'freeDownloadClick'
                        });
                    });
                }
                // track API related result clicks
                const affiliateApiLinks = document.querySelectorAll('.stock-api-results a');
                affiliateApiLinks.forEach(link => {
                    link.addEventListener('click', () => {
                        window.fullres ||= {events: []};
                        window.fullres.events.push({ 
                            key: 'affiliateApiClick', 
                            affiliateType: 'API Related Results'
                        });
                    });
                });
                // track affiliate discount code link clicks
                const affiliateDiscountLinks = document.querySelectorAll('.stock-section__title, .single-right__sstk a');
                affiliateDiscountLinks.forEach(link => {
                    link.addEventListener('click', () => {
                        window.fullres ||= {events: []};
                        window.fullres.events.push({ 
                            key: 'affiliatePromoClick', 
                            affiliateType: 'Promo Code'
                        });
                    });
                });
            });
        </script>
