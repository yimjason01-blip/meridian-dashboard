            window.localeCode       = 'en'
            window.livewire_app_url = "vectorportal.com/en"
            window.searchTotal      = ''
            // add a 'no-results' class to BODY if no search results exist
            document.addEventListener("DOMContentLoaded", function() {
                if (window.searchTotal == '0') {
                    document.body.classList.add('no-results');
